# Copy to backend/.env

# Password reset: SPA URL (must match Vite port, e.g. 8080 or 5173)
# FRONTEND_BASE_URL=http://localhost:8080
# Token lifetime in minutes
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# Dev: API returns reset link + token in JSON (set false in production)
# PASSWORD_RESET_RETURN_TOKEN=true

# Optional SMTP (when SMTP_HOST is set, forgot-password emails the link)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# --- Kanban automation (Groq + optional RAG) ---
# TASK_AUTOMATION_EXTRACT_MAX_TOKENS=3072
# TASK_AUTOMATION_BOARD_SYNC_MAX_TOKENS=2048
# KANBAN_RAG_ENABLED=true
# KANBAN_EMBEDDING_MODEL=all-MiniLM-L6-v2
# KANBAN_RAG_CHUNK_WORDS=250
# KANBAN_RAG_CHUNK_OVERLAP_WORDS=40
# KANBAN_RAG_TOP_K=5
# KANBAN_RAG_MAX_CONTEXT_CHARS=12000
# KANBAN_RAG_MIN_SIMILARITY=0.22
# KANBAN_RAG_LATEST_MEETING_SCORE_BOOST=1.12
# KANBAN_RAG_QUERIES=
# KANBAN_RAG_FALLBACK_TAIL_CHARS=8000
# KANBAN_RAG_BOARD_SYNC_ENABLED=true
# KANBAN_RAG_BOARD_MAX_TRANSCRIPT_CHARS=10000

# --- GitHub webhooks (Kanban task completion from Git) ---
#
# IMPORTANT: The Kanban board does NOT read your local Git client. It only updates when GitHub
# POSTs to this API. If you commit locally but no webhook fires (or it fails), tasks stay unchanged.
#
# Webhook URL (GitHub → Settings → Webhooks → Add webhook):
#   Payload URL: https://YOUR_PUBLIC_API_HOST/api/v1/webhooks/github
#   Content type: application/json
#   Secret: same value as GITHUB_WEBHOOK_SECRET below (HMAC SHA-256)
# Events: at least "Pull requests". Add "Pushes" only if GITHUB_REQUIRE_PR_MERGE_FOR_DONE=false.
#         Add "Workflow runs" if you use GITHUB_REQUIRE_CI_SUCCESS_FOR_DONE or CI-driven blockers.
#
# Verify webhook delivery (todo: operator):
#   1) GitHub → Webhooks → Recent Deliveries: HTTP should be 200 (not 403/503).
#   2) Open the delivery → Response body: JSON may include "skipped" with a reason, e.g.
#      no_project_for_repo, invalid_signature, push_ignored_require_pr_merge, pr_not_merged,
#      no_task_keys_in_pr, push_no_matching_commits.
#   3) Server logs: search for "GitHub webhook" in backend output.
#
# Verify project + task keys (todo: operator):
#   1) Workspace project must have github_full_name = owner/repo (lowercase) and github_webhook_enabled=true
#      (set via manager PATCH /projects/{id}/github or equivalent UI).
#    2) Task key format: PREFIX + "-" + 8+ hex chars (default PREFIX=MM from GITHUB_TASK_KEY_PREFIX).
#      Copy the key from the task card; it must match text in the PR title or PR body (merged PR path).
#   3) If GITHUB_REQUIRE_PR_MERGE_FOR_DONE=true (default): pushes are ignored for Done. Use a merged PR
#      whose title/body contains the task key. Commit messages alone are not read for that path.
#   4) If GITHUB_REQUIRE_PR_MERGE_FOR_DONE=false: default-branch push commits can mark Done only when
#      the commit message contains a closing keyword (fix|closes|complete|done) AND the task key.
#
# Local dev: GitHub cannot reach localhost; use ngrok/Cloudflare Tunnel (or similar) for the Payload URL.
#
# Required for POST /api/v1/webhooks/github — HMAC X-Hub-Signature-256 (503 if unset)
# GITHUB_WEBHOOK_SECRET=
# Task keys in commits/PRs: PREFIX-XXXXXXXX (8 hex chars from task ObjectId)
# GITHUB_TASK_KEY_PREFIX=MM
# Optional: re-fetch PR merged state via GitHub REST
# GITHUB_PAT=
# If true, only merged PRs (title/body) can mark DONE; if false, push + keywords also allowed
# GITHUB_REQUIRE_PR_MERGE_FOR_DONE=true
# CI gate: merged PR completes tasks only if latest workflow_run for this PR head reported success
# GITHUB_REQUIRE_CI_SUCCESS_FOR_DONE=false
# Optional: only react to these workflow names (comma-separated). Empty = all.
# GITHUB_CI_WORKFLOW_NAME_ALLOWLIST=Run Tests
#
# Strongly set GITHUB_PAT when using CI gating so merge vs CI ordering is handled (finalize after CI).

# --- CI / pytest (local + GitHub Actions) ---
# From repo root: pip install -r backend/requirements.txt && cd backend && pytest tests -q

# --- Stale tasks (inactivity → Blockers column) ---
# STALE_TASK_AUTO_BLOCKERS_ENABLED=false
# STALE_TASK_INACTIVITY_DAYS=3
# When enabled, opening GET /projects/{id} runs the check. Optional background:
# STALE_TASK_BACKGROUND_INTERVAL_HOURS=0
# Example: 6 = sweep all projects every 6 hours (still requires STALE_TASK_AUTO_BLOCKERS_ENABLED=true)
