# Copy to backend/.env

# Password reset: SPA URL (must match Vite port, e.g. 8080 or 5173)
# FRONTEND_BASE_URL=http://localhost:8080
# Token lifetime in minutes
# PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
# Dev: API returns reset link + token in JSON (set false in production)
# PASSWORD_RESET_RETURN_TOKEN=true

# Optional SMTP (when SMTP_HOST is set, forgot-password emails the link)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true

# --- Kanban automation (Groq + optional RAG) ---
# TASK_AUTOMATION_EXTRACT_MAX_TOKENS=3072
# TASK_AUTOMATION_BOARD_SYNC_MAX_TOKENS=2048
# KANBAN_RAG_ENABLED=true
# KANBAN_EMBEDDING_MODEL=all-MiniLM-L6-v2
# KANBAN_RAG_CHUNK_WORDS=250
# KANBAN_RAG_CHUNK_OVERLAP_WORDS=40
# KANBAN_RAG_TOP_K=5
# KANBAN_RAG_MAX_CONTEXT_CHARS=12000
# KANBAN_RAG_MIN_SIMILARITY=0.22
# KANBAN_RAG_LATEST_MEETING_SCORE_BOOST=1.12
# KANBAN_RAG_QUERIES=
# KANBAN_RAG_FALLBACK_TAIL_CHARS=8000
# KANBAN_RAG_BOARD_SYNC_ENABLED=true
# KANBAN_RAG_BOARD_MAX_TRANSCRIPT_CHARS=10000

# --- GitHub webhooks (Kanban task completion) ---
# Required for POST /api/v1/webhooks/github — HMAC X-Hub-Signature-256
# GITHUB_WEBHOOK_SECRET=
# Task keys in commits/PRs: PREFIX-XXXXXXXX (8 hex chars from task ObjectId)
# GITHUB_TASK_KEY_PREFIX=MM
# Optional: re-fetch PR merged state via GitHub REST
# GITHUB_PAT=
# If true, only merged PRs (title/body) can mark DONE; if false, push + keywords also allowed
# GITHUB_REQUIRE_PR_MERGE_FOR_DONE=true
# CI gate: merged PR completes tasks only if latest workflow_run for this PR head reported success
# GITHUB_REQUIRE_CI_SUCCESS_FOR_DONE=false
# Optional: only react to these workflow names (comma-separated). Empty = all.
# GITHUB_CI_WORKFLOW_NAME_ALLOWLIST=Run Tests
#
# GitHub repo webhook: enable event "Workflow runs" (workflow_run) for CI updates.
# Strongly set GITHUB_PAT when using CI gating so merge vs CI ordering is handled (finalize after CI).

# --- CI / pytest (local + GitHub Actions) ---
# From repo root: pip install -r backend/requirements.txt && cd backend && pytest tests -q
#
# GitHub → repo → Settings → Webhooks → Edit:
#   Enable “Workflow runs” (workflow_run) in addition to pull requests if you use CI gating.

# --- Stale tasks (inactivity → Blockers column) ---
# STALE_TASK_AUTO_BLOCKERS_ENABLED=false
# STALE_TASK_INACTIVITY_DAYS=3
# When enabled, opening GET /projects/{id} runs the check. Optional background:
# STALE_TASK_BACKGROUND_INTERVAL_HOURS=0
# Example: 6 = sweep all projects every 6 hours (still requires STALE_TASK_AUTO_BLOCKERS_ENABLED=true)
